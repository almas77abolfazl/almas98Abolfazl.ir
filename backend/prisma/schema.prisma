generator client {
  provider = "prisma-client-js"
}

datasource db {
   provider = "postgresql"
 }

model AboutMe {
  id          String   @id @default(uuid())
  fullName    String
  fullNameFa  String?
  title       String
  titleFa     String?
  bio         String?  @db.Text
  bioFa       String?  @db.Text
  avatarUrl   String?
  resumeUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Experiences {
  id          String   @id @default(uuid())
  role        String
  roleFa      String?
  company     String
  companyFa   String?
  startDate   DateTime
  endDate     DateTime?
  description String?  @db.Text
  descriptionFa String? @db.Text
  technologies String[]
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Educations {
  id            String   @id @default(uuid())
  degree        String
  degreeFa      String?
  institution   String
  institutionFa String?
  field         String?
  fieldFa       String?
  startDate     DateTime
  endDate       DateTime?
  description   String?  @db.Text
  descriptionFa String?  @db.Text
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Skills {
  id          String   @id @default(uuid())
  name        String
  nameFa      String?
  category    String
  categoryFa  String?
  proficiency Int?     @default(0)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Articles {
  id          String   @id @default(uuid())
  title       String
  titleFa     String?
  slug        String   @unique
  content     String   @db.Text
  contentFa   String?  @db.Text
  excerpt     String?  @db.Text
  excerptFa   String?  @db.Text
  coverUrl    String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Media {
  id          String   @id @default(uuid())
  filename    String
  originalName String
  mimeType    String
  sizeBytes   Int
  url         String
  alt         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String?
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Testimonial {
  id            String    @id @default(uuid())
  authorName    String
  authorNameFa  String?
  companyRole   String?
  companyRoleFa String?
  content       String    @db.Text
  contentFa     String?   @db.Text
  rating        Int?
  status        TestimonialStatus @default(PENDING)
  createdAt     DateTime  @default(now())
}

enum TestimonialStatus {
  PENDING
  APPROVED
  REJECTED
}

model PageView {
  id        String   @id @default(uuid())
  url       String
  ipHash    String?
  createdAt DateTime @default(now())
}
