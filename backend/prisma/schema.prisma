generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AboutMe {
  id          String   @id @default(uuid())
  fullName    String
  title       String
  bio         String?  @db.Text
  avatarUrl   String?
  resumeUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Experiences {
  id          String   @id @default(uuid())
  role        String
  company     String
  startDate   DateTime
  endDate     DateTime?
  description String?  @db.Text
  technologies String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Educations {
  id          String   @id @default(uuid())
  degree      String
  institution String
  field       String?
  startDate   DateTime
  endDate     DateTime?
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Skills {
  id          String   @id @default(uuid())
  name        String
  category    String
  proficiency Int?     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Articles {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  excerpt     String?  @db.Text
  coverUrl    String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Media {
  id          String   @id @default(uuid())
  filename    String
  originalName String
  mimeType    String
  sizeBytes   Int
  url         String
  alt         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
